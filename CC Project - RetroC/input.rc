int factorial(int n) {
    int result;
    result = 1;
    for(int i=1; i<n; i++){
        result = result * i;
    }
    return result;
}

int main() {
    int x;
    x = factorial(5);
    int sum;
    sum = 10 + 6;
    return sum;
}